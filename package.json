{
  "name": "lattice-app-template",
  "version": "1.0.0",
  "private": true,
  "description": "Lattice — web app monorepo starter (DDD API, Turborepo; Next.js and infra planned)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/lattice-app-template.git"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "start": "turbo run build && npm run start -w @lattice/api",
    "dev": "turbo run dev",
    "test": "jest --colors",
    "test:watch": "jest --watch --colors",
    "test:coverage": "jest --coverage --colors",
    "test:verbose": "jest --verbose --colors",
    "test:web:unit": "vitest run --config test/web/vitest.config.ts",
    "test:web:unit:watch": "vitest --config test/web/vitest.config.ts",
    "test:web:e2e": "playwright test --config test/web/playwright.config.ts",
    "test:web:e2e:ui": "playwright test --config test/web/playwright.config.ts --ui",
    "type-check": "turbo run type-check",
    "install:all": "npm install",
    "api:build:lambda": "npm run build:lambda -w @lattice/api",
    "web:build:static": "npm run build:static -w @lattice/web",
    "clean": "rm -rf apps/api/dist apps/api/node_modules/.cache apps/web/.next apps/web/node_modules/.cache test/coverage test/web/test-results test/web/playwright-report",
    "lint": "turbo run lint type-check",
    "ci": "turbo run build lint type-check \"//#test:coverage\" \"//#test:web:unit\"",
    "infra:fmt": "terraform fmt -recursive infra/terraform",
    "infra:fmt:check": "terraform fmt -check -recursive infra/terraform",
    "infra:validate": "cd infra/terraform/envs/dev && terraform init -backend=false -input=false && terraform validate",
    "fork:check": "node scripts/fork.mjs check",
    "fork:init": "node scripts/fork.mjs init",
    "scaffold": "node scripts/scaffold.mjs",
    "repo-features:apply": "node scripts/apply-repo-features.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.7.0",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.3",
    "jsdom": "^26.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "turbo": "^2.4.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test/api"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "apps/api/**/*.ts",
      "!apps/api/**/*.d.ts",
      "!apps/api/dist/**"
    ],
    "moduleNameMapper": {
      "^@api/(.*)$": "<rootDir>/apps/api/$1"
    },
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "<rootDir>/tsconfig.json"
        }
      ]
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "coverageDirectory": "<rootDir>/test/coverage"
  }
}
