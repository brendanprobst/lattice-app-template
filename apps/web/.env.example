# Copy to `.env.local` for local Next.js overrides (not committed).
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# API base URL used by the browser (Express API default port is 3000; web dev is 3001).
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000

# Supabase (browser / anon key). Required for sign-in and session on `/auth/*`, `/profile`, `/things`.
# Add your deployed and local reset URL to Authentication → URL Configuration → Redirect URLs (e.g. http://localhost:3001/auth/reset-password).
# From Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OAuth provider for "Continue with …" on the login page (default: google).
# NEXT_PUBLIC_SUPABASE_OAUTH_PROVIDER=google

# Optional: override GitHub/template links on the home page (defaults to this template repo).
# NEXT_PUBLIC_TEMPLATE_REPO_URL=https://github.com/your-org/your-repo

# PostHog (optional). Off unless you set all three: enabled flag + token + (optional) host.
# See `docs/playbooks/posthog-analytics.md`.
# NEXT_PUBLIC_LATTICE_POSTHOG_ENABLED=1
# NEXT_PUBLIC_POSTHOG_TOKEN=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Playwright E2E only — do not set in normal dev (see `test/web/playwright.config.ts`).
# NEXT_PUBLIC_LATTICE_E2E=1
# NEXT_PUBLIC_LATTICE_E2E_ACCESS_TOKEN=
