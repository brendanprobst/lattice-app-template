# Server Configuration
PORT=3000

# Supabase (optional for local dev — if omitted, API uses in-memory Thing storage; required for production)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_THINGS_TABLE=things

# JWT verification for API auth middleware
# Default: JWKS via SUPABASE_URL + issuer/audience (recommended)
# Optional legacy/test fallback: set SUPABASE_JWT_SECRET for HS256 verification.
# SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# Browser origins allowed to call API (comma-separated)
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
