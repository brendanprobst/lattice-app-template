{
  "name": "@lattice/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:lambda": "esbuild lambda.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist-lambda/index.js",
    "start": "node ./dist/bin/www.js",
    "dev": "ts-node-dev --respawn --transpile-only ./bin/www.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.1019.0",
    "@vendia/serverless-express": "^4.12.6",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.6",
    "debug": "~2.6.9",
    "dotenv": "^16.4.5",
    "express": "~4.16.1",
    "http-errors": "~1.6.3",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "~1.9.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.21",
    "@types/http-errors": "^2.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.3.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "chalk": "^4.1.2",
    "esbuild": "^0.27.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
