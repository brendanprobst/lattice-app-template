{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@api/*": ["apps/api/*"]
    },
    "types": ["jest", "node"]
  },
  "include": ["test/**/*.ts"],
  "exclude": ["node_modules", "apps/api/dist"]
}
