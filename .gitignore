# Node modules
**/node_modules/
# Root package-lock.json is committed for reproducible installs (npm ci).
# Workspace packages must not carry their own lockfiles.
apps/**/package-lock.json
**/.env
**/.env.*
!.env.example
!**/.env.example
.env
# TypeScript build output
**/dist/
**/dist-lambda/

# Turborepo
**/.turbo/

# Jest coverage (root tests; see package.json jest.coverageDirectory)
test/coverage/
*.lcov

# Playwright
playwright-report/
test-results/
blob-report/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Terraform (keep .terraform.lock.hcl committed)
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.tfstate.lock.info
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json