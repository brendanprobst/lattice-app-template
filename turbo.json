{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "type-check": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "//#test": {
      "dependsOn": ["@lattice/api#build", "@lattice/web#build"],
      "inputs": [
        "package.json",
        "tsconfig.json",
        "test/api/**/*.ts",
        "apps/api/**/*.ts",
        "!apps/api/dist/**"
      ],
      "outputs": []
    },
    "//#test:coverage": {
      "dependsOn": ["@lattice/api#build", "@lattice/web#build"],
      "inputs": [
        "package.json",
        "tsconfig.json",
        "test/api/**/*.ts",
        "apps/api/**/*.ts",
        "!apps/api/dist/**"
      ],
      "outputs": ["test/coverage/**"]
    },
    "//#test:web:unit": {
      "dependsOn": ["@lattice/web#build"],
      "inputs": [
        "package.json",
        "test/web/**/*.ts",
        "test/web/**/*.tsx",
        "apps/web/client/**/*.ts",
        "apps/web/client/**/*.tsx",
        "apps/web/app/**/*.tsx"
      ],
      "outputs": []
    },
    "//#test:web:e2e": {
      "cache": false,
      "dependsOn": [],
      "inputs": [
        "package.json",
        "test/web/**",
        "apps/web/**",
        "!apps/web/node_modules/**",
        "!apps/web/.next/**"
      ],
      "outputs": []
    }
  }
}
